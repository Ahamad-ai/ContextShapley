# ContextShapley Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# --- OpenAI API (for GPT-5 / GPT-4o experiments) ---
# Required if running with --provider openai
OPENAI_API_KEY=your-openai-api-key-here

# --- Ollama (for Qwen3:8B and other local models) ---
# Install Ollama: https://ollama.com/download
# Pull the model: ollama pull qwen3:8b
# Ollama runs locally on port 11434 by default; no API key needed.
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- AWS Bedrock (for Claude models, optional) ---
# Required if running with --provider bedrock
# Configure AWS credentials via `aws configure` or environment variables:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1
